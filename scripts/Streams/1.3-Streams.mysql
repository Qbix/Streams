CREATE TABLE `{{prefix}}workspace` (
    `publisherId` varbinary(31) NOT NULL DEFAULT '' COMMENT 'id of user that publishes the workspace',
    `name` varbinary(15) NOT NULL,
    `parentName` varbinary(15) NULL DEFAULT NULL,
    `insertedTime` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'saved on shard of publisherId',
    `updatedTime` timestamp NULL DEFAULT NULL COMMENT 'the time that this row has last changed for whatever reason',
    PRIMARY KEY (`publisherId`, `name`),
    KEY `byParent` (`publisherId`, `parentName`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;